pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
function _init()
 health = 100
end

function _draw()
 cls()
 print("health:"..health,8,8,7)
 rect(14,14,110,20,7)
 rectfill(16,16,16+health,18,13)
end

function _update()
 sfx(0)
 health -= 0.1
end
